# ============================================
# NAUTOS AI — Environment Variables
# Copy this file: cp .env.example .env
# Fill in all values marked with <...>
# ============================================

# --- Database (PostgreSQL + pgvector) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nautos
DB_USER=nautos_user
DB_PASS=<strong_password_here>
DATABASE_URL=postgresql://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- App (Next.js) ---
NODE_ENV=development
PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<random_64_char_string>
JWT_SECRET=<random_64_char_string>

# --- LLM Provider Selection ---
# Set to "groq" (recommended free), "gemini" (free tier), or "anthropic" (paid).
LLM_PROVIDER=groq

# --- Groq (recommended free tier: 30 RPM, 14,400 req/day, no card needed) ---
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=<your_groq_key>

# --- Google Gemini (free tier: 15 RPM, 1M tokens/day) ---
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your_gemini_key>

# --- Anthropic Claude (paid — optional, only if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=<sk-ant-...>

# --- Voyage AI (Embeddings) ---
VOYAGE_API_KEY=<pa-...>

# --- Azure Document Intelligence (OCR) ---
AZURE_DI_ENDPOINT=<https://your-resource.cognitiveservices.azure.com/>
AZURE_DI_KEY=<your_azure_key>

# --- AWS S3 (Document Storage) ---
AWS_REGION=ap-south-1
AWS_S3_BUCKET=nautos-documents
AWS_ACCESS_KEY_ID=<your_access_key>
AWS_SECRET_ACCESS_KEY=<your_secret_key>

# --- Resend (Email) ---
RESEND_API_KEY=<re_...>

# --- Frontend URL (for CORS + emails) ---
FRONTEND_URL=http://localhost:3000
